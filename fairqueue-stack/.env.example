DATABASE_URL=postgresql+asyncpg://fairqueue:fairqueue@postgres:5432/fairqueue
REDIS_URL=redis://redis:6379/0
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
OTP_EXPIRE_MINUTES=10
RETURN_DEV_OTP=true
ADMIN_EMAIL=admin@fairqueue.local
ADMIN_PASSWORD=AdminPass123!
ADMISSION_BATCH=5
ADMISSION_INTERVAL_MS=4000
MAX_ADMITTED_PER_TRAIN=20
LOCK_TTL_SECONDS=90
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_SEC=10
NEXT_PUBLIC_API_URL=http://localhost:8000
# Set to "true" in .env.local (development only) to show the clickable dev OTP panel
NEXT_PUBLIC_SHOW_DEV_OTP=true
